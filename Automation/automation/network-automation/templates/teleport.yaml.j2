version: v3
teleport:
  nodename: {{ ansible_hostname }}
  data_dir: /var/lib/teleport
  auth_server: teleport.anphuc.site:3025
  auth_token: "{{ hostvars['teleport-server']['dynamic_join_token'] }}"
  log:
    output: stderr
    severity: INFO
auth_service:
  enabled: "no"
ssh_service:
  enabled: "yes"
  labels:
    namesv: "{{ ansible_hostname }}"
proxy_service:
  enabled: "no"
