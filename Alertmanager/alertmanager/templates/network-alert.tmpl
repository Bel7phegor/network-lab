{{ define "network.alert" }}
{{ if eq .Status "firing" }}
{{ if eq .Labels.severity "warning" }}⚠️ {{ .Labels.alertname }} ⚠️
{{ else if eq .Labels.severity "critical" }}🚨 {{ .Labels.alertname }} 🚨
{{ else }}🛑 {{ .Labels.alertname }} 🛑
{{ end }}
{{ else }}✅ {{ .Labels.alertname }} RECOVERED ✅
{{ end }}

<b>Interface:</b> {{ .Labels.ifName }} ({{ or .Labels.ifAlias "N/A" }})
<b>Instance:</b> {{ .Labels.instance }}
<b>Traffic:</b> {{ .Value }} bps
<b>Approx:</b> ~{{ .Value }} bps ({{ or .Labels.traffic_mbps "N/A" }} Mbps)
{{ range .Annotations.SortedPairs }}
<b>{{ .Name }}:</b> {{ .Value }}
{{ end }}

{{ if eq .Status "firing" }}<i>Triggered:</i> {{ .StartsAt.Format "2006-01-02 15:04:05" }}
{{ else }}<i>Resolved:</i> {{ .EndsAt.Format "2006-01-02 15:04:05" }}
{{ end }}
{{ end }}
